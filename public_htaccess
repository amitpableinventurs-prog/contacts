Options -Indexes
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Old URLs used /contacts/public/... — permanently redirect them to
    # /contacts/... so bookmarks keep working. THE_REQUEST matches only the
    # original browser request, never the internal rewrite below (no loop).
    RewriteCond %{THE_REQUEST} \s/+contacts/public[/\s?]
    RewriteRule ^public(?:/(.*))?$ /contacts/$1 [R=301,L]

    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
